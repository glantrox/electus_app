# ============================================
# Electus App - Environment Configuration
# ============================================
# Copy this file to `.env` and fill in the values.

# Base URL for the backend API server.
# - iOS Simulator:    http://localhost:3000
# - Android Emulator: http://10.0.2.2:3000
# - Physical Device:  http://<your-machine-ip>:3000
API_BASE_URL=http://localhost:3000

# Default avatar image URL (used when user has no profile picture).
DEFAULT_AVATAR_URL=https://i.pravatar.cc/150?img=47

# Device name sent with authentication requests.
DEVICE_NAME=Flutter Client
